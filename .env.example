# LLM routing — "docker" (Docker Model Runner), "ollama", or "claude"
DEFAULT_LLM=docker

# Docker Model Runner (built into Docker Desktop — no separate install)
# Enable: Docker Desktop → Settings → Features in development → Docker Model Runner
# Pull a model: docker model pull ai/qwen2.5
# NOTE: MODEL_RUNNER_MODEL must match an id from `docker model ls` EXACTLY,
# including any tag. A pull can resolve to a tagged id (e.g. ai/llama3.2:3B-Q4_K_M);
# if it does, put that full id here or the runner returns 404 (model not found).
MODEL_RUNNER_URL=http://localhost:12434/engines/llama.cpp/v1
# Everyday / simple-and-tool model. An instruct model (qwen2.5) is the most
# reliable at tool-use (weather, search) and casual chat.
MODEL_RUNNER_MODEL=ai/qwen2.5:latest
# Optional: a second local model for coding / technical tasks. When set (and
# different from the above), coding-flavoured queries auto-route here while
# everything else stays on MODEL_RUNNER_MODEL; anything beyond both still
# escalates to Claude. Leave blank to use one model for everything.
# e.g. MODEL_RUNNER_CODE_MODEL=ai/qwen3-coder:32k
MODEL_RUNNER_CODE_MODEL=

# Ollama (alternative local backend)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Claude (only needed if DEFAULT_LLM=claude or routing escalates)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Complexity threshold: word count above which a query routes to Claude
COMPLEX_QUERY_THRESHOLD=200

# Escalation — try the local model first; if it can't answer, Victoria asks
# permission to escalate to the Claude Code CLI (uses your Claude subscription,
# no API key needed — just have `claude` installed and logged in).
ESCALATION_ENABLED=true
CLAUDE_CLI_COMMAND=claude
CLAUDE_CLI_MODEL=sonnet
CLAUDE_CLI_TIMEOUT=120
# Optional: a long-lived token from `claude setup-token`. Set this if escalation
# fails with a 401 — it makes Claude auth work no matter how Victoria is launched
# (no dependence on an interactive `claude` login in the launch shell). Leave
# blank to use your normal subscription login.
CLAUDE_CLI_OAUTH_TOKEN=
# Read-only tools Claude may use non-interactively (space/comma separated).
# WebSearch/WebFetch let it answer real-time questions; nothing else is allowed.
CLAUDE_CLI_ALLOWED_TOOLS=WebSearch WebFetch

# Data
DB_PATH=data/victoria.db
CHROMADB_PATH=data/chromadb

# Skills — directory of Markdown skill files Victoria can apply and create
SKILLS_PATH=skills

# Knowledge bases (Obsidian) — folders of Markdown notes Victoria can read,
# search, and update by talking to her. With Obsidian Sync those folders stay
# in step across machines. (Distinct from the Credentials Vault above — these
# hold notes, not secrets.)
#
# RECOMMENDED — single-vault mode: point Victoria at ONE Obsidian vault. She
# sees everything in it, and its top-level folders (Docker/, Personal/, Brain/…)
# act as areas she can target ("save to Personal", "search my Docker notes").
OBSIDIAN_VAULT_PATH=
#
# ALTERNATIVE — per-area mode: three independent vault folders (blank = disabled).
# Ignored when OBSIDIAN_VAULT_PATH is set.
OBSIDIAN_DOCKER_PATH=
OBSIDIAN_PERSONAL_PATH=
OBSIDIAN_AI_PATH=
# Which per-area vaults Victoria may write to (comma-separated); others read-only.
OBSIDIAN_WRITABLE=docker,personal,ai
# Vault/area that will hold Victoria's own durable memory (Phase 2+).
OBSIDIAN_MEMORY_VAULT=ai

# Voice (Week 5)
# TTS_ENGINE: "piper" (local, free) or "elevenlabs" (cloud, paid)
TTS_ENGINE=piper
PIPER_MODEL_PATH=models/en_GB-jenny_dioco-medium.onnx
WHISPER_MODEL=base
WAKE_WORD=hello victoria

# ElevenLabs TTS (only needed when TTS_ENGINE=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_monolingual_v1
VOICE_SESSION_TIMEOUT=30

# Telegram — get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
