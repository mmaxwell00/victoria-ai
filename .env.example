# LLM routing — "docker" (Docker Model Runner), "ollama", or "claude"
DEFAULT_LLM=docker

# Docker Model Runner (built into Docker Desktop — no separate install)
# Enable: Docker Desktop → Settings → Features in development → Docker Model Runner
# Pull a model: docker model pull ai/llama3.2
# NOTE: MODEL_RUNNER_MODEL must match an id from `docker model ls` EXACTLY,
# including any tag. A pull can resolve to a tagged id (e.g. ai/llama3.2:3B-Q4_K_M);
# if it does, put that full id here or the runner returns 404 (model not found).
MODEL_RUNNER_URL=http://localhost:12434/engines/llama.cpp/v1
MODEL_RUNNER_MODEL=ai/llama3.2

# Ollama (alternative local backend)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Claude (only needed if DEFAULT_LLM=claude or routing escalates)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Complexity threshold: word count above which a query routes to Claude
COMPLEX_QUERY_THRESHOLD=200

# Data
DB_PATH=data/victoria.db
CHROMADB_PATH=data/chromadb

# Voice (Week 5)
# TTS_ENGINE: "piper" (local, free) or "elevenlabs" (cloud, paid)
TTS_ENGINE=piper
PIPER_MODEL_PATH=models/en_GB-jenny_dioco-medium.onnx
WHISPER_MODEL=base
WAKE_WORD=hello victoria

# ElevenLabs TTS (only needed when TTS_ENGINE=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_monolingual_v1
VOICE_SESSION_TIMEOUT=30

# Telegram — get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
